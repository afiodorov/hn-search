# Database Configuration
# PostgreSQL with pgvector extension
DATABASE_URL=postgres://user:password@host:port/database

# LLM API Keys
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# Redis Cache (optional but recommended)
# Improves query performance by 50-100x for repeated queries
REDIS_URL=redis://localhost:6379

# Google Cloud Platform (for BigQuery data fetching)
# Only needed for incremental updates
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Tokenizers Configuration
# Set to false to avoid warnings in multi-threaded environments
TOKENIZERS_PARALLELISM=false

# Port Configuration (optional)
# Default port for Gradio web UI
PORT=7860

# Vector search backend (pg | rust | shadow)
#   pg     — Postgres/pgvector only (default)
#   rust   — the standalone Rust brute-force service
#   shadow — run both, log top-k overlap + latency, return pg results
HN_SEARCH_BACKEND=pg
# Base URL of the Rust search service (rust/shadow backends)
HN_SEARCH_URL=https://search.example.com
# READ token — grants /search only. Safe to put on the public web app (Railway).
HN_SEARCH_TOKEN=change-me-read
# ADMIN token — grants /append + /max_id. Keep ONLY where updates run (your laptop);
# never deploy it to the public web app. Used by misc/fetch_and_embed_new_comments.py.
HN_SEARCH_ADMIN_TOKEN=change-me-admin
# Per-request timeout in seconds (optional)
HN_SEARCH_TIMEOUT=10
