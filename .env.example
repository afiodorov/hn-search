# Rust search service
# Base URL of the service (the web app calls /search; updates call /append + /max_id)
HN_SEARCH_URL=https://search.example.com
# READ token — grants /search only. Safe on the public web app (Railway).
HN_SEARCH_TOKEN=change-me-read
# ADMIN token — grants /append + /max_id. Keep ONLY where updates run (your laptop);
# never deploy it to the public web app. Used by misc/fetch_and_embed_new_comments.py.
HN_SEARCH_ADMIN_TOKEN=change-me-admin
# Per-request timeout in seconds (optional)
HN_SEARCH_TIMEOUT=10

# LLM API Keys
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-api-key-here

# Redis Cache (result + answer + job caching)
REDIS_URL=redis://localhost:6379

# Google Cloud Platform (BigQuery, for incremental updates only)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Tokenizers (avoid multi-threaded warnings)
TOKENIZERS_PARALLELISM=false

# Web server port (optional)
PORT=7860
